<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo2.mapper.CategoryItemMapper">

    <resultMap id="CategoryItemMap" type="com.example.demo2.model.CategoryItem">
        <id property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="isChecked" column="is_checked"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="CategoryItemMap">
        SELECT * FROM category_items ORDER BY sort_order ASC, name ASC
    </select>

    <select id="findByParentId" resultMap="CategoryItemMap">
        SELECT * FROM category_items 
        WHERE <if test="parentId == null">parent_id IS NULL</if>
              <if test="parentId != null">parent_id = #{parentId}</if>
        ORDER BY sort_order ASC, name ASC
    </select>

    <select id="findById" resultMap="CategoryItemMap">
        SELECT * FROM category_items WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category_items (parent_id, name, is_checked, sort_order)
        VALUES (#{parentId}, #{name}, #{isChecked}, #{sortOrder})
    </insert>

    <update id="update">
        UPDATE category_items
        SET parent_id = #{parentId},
            name = #{name},
            is_checked = #{isChecked},
            sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM category_items WHERE id = #{id}
    </delete>

    <update id="updateChecked">
        UPDATE category_items
        SET is_checked = #{isChecked}
        WHERE id = #{id}
    </update>

</mapper>
